# Shioaji API - Simulation (模擬環境)
SHIOAJI_API_KEY_SIM=YOUR_SIM_KEY_HERE
SHIOAJI_SECRET_KEY_SIM=YOUR_SIM_SECRET_HERE

# Shioaji API - Production (正式環境)
SHIOAJI_API_KEY_PROD=YOUR_PROD_KEY_HERE
SHIOAJI_SECRET_KEY_PROD=YOUR_PROD_SECRET_HERE

# Certificate Settings
SHIOAJI_CERT_PATH=./cert/Sinopac.pfx
SHIOAJI_CERT_PASSWORD=YOUR_PASSWORD_HERE
SHIOAJI_PERSON_ID=YOUR_ID_HERE

# Default Mode (true/false)
SHIOAJI_SIMULATION=true

# Gemini API（新聞摘要子模組）
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
NEWS_SUMMARIZER_BACKEND=gemini    # gemini（SDK）或 gemini-cli（subprocess 備案）
